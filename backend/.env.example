PORT=4000
NODE_ENV=development

# MongoDB Atlas — crear usuario DEDICADO, no compartir credenciales
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@cluster.mongodb.net/lesmoda

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=genera_un_secreto_unico_aqui
JWT_EXPIRES_IN=7d

# Cloudinary — registrar API Key/Secret desde dashboard.cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# CORS — dominio exacto del frontend (separar con comas si varios)
CLIENT_URL=http://localhost:5173

WA_NUMBER=519XXXXXXXX

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false
